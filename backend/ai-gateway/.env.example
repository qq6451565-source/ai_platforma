# ──────────────────────────────────────────────
# AI Gateway Environment Configuration
# ──────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# cp .env.example .env

# ── Security ──────────────────────────────────
# Required: API key for authenticating requests
AI_API_KEY=change-me-to-a-strong-random-secret

# Enable debug mode (exposes /docs and /redoc; use false in production)
DEBUG=false

# Comma-separated list of allowed CORS origins (use * for all in dev only)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Face Detection ────────────────────────────
# DeepFace model: Facenet, Facenet512, ArcFace, Dlib, SFace, GhostFaceNet
FACE_MODEL=Facenet512

# Detector backend: opencv, ssd, mtcnn, retinaface, mediapipe
DETECTION_BACKEND=opencv

# Enforce face detection (false = return error only if no face found)
ENFORCE_DETECTION=false

# ── Thresholds ────────────────────────────────
FACE_MATCH_THRESHOLD=0.55
PRESENCE_THRESHOLD=0.5
OCR_CONFIDENCE_THRESHOLD=0.0

# ── Image Limits ──────────────────────────────
MAX_IMAGE_SIZE_MB=8

# ── Image Quality Thresholds ─────────────────
FACE_QUALITY_MIN_BRIGHTNESS=40
FACE_QUALITY_MAX_BRIGHTNESS=220
FACE_QUALITY_MIN_SHARPNESS=35
FACE_QUALITY_MIN_FACE_RATIO=0.08
FACE_QUALITY_MAX_FACE_RATIO=0.75

# ── Server ────────────────────────────────────
PORT=7860
