# AI Gateway config
AI_ENABLED=true
AI_BASE_URL=http://ai-gateway:8001
AI_API_KEY=change-me

# OCR
OCR_CONFIDENCE_THRESHOLD=0.2
OCR_LANGS=en,ru
OCR_GPU=false
OCR_MAX_SIDE=1600
OCR_MIN_SIDE=1200
OCR_CARD_DIGITS=7

# Face match
FACE_MATCH_THRESHOLD=0.55
FACE_MODEL=Facenet512
DETECTION_BACKEND=opencv
FACE_MIN_AREA=2500

# Presence detection
PRESENCE_THRESHOLD=0.5

# File size limit (MB)
MAX_IMAGE_SIZE_MB=8

# Debug
DEBUG=false

# Logging
LOG_PATH=./logs/ai-gateway.log
LOG_LEVEL=info
